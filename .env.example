# ============================================================
# TransactionAggregationAPI — Required Environment Variables
# ============================================================
# Copy this file to .env and fill in values.
# NEVER commit .env with real secrets.
# All variables must be set; the application will fail fast if any are missing.

# PostgreSQL connection string (Npgsql format)
# Pool settings are configured in code (MinPoolSize=10, MaxPoolSize=100)
ConnectionStrings__Postgres=Host=localhost;Port=5432;Database=transactions;Username=appuser;Password=CHANGE_ME

# Redis connection string
Redis__ConnectionString=localhost:6379

# API keys — comma-separated list (at least one required)
# Each caller must send X-API-Key header with one of these values
ApiKeys__0=REPLACE_WITH_SECURE_KEY_1
ApiKeys__1=REPLACE_WITH_SECURE_KEY_2

# CORS — allowed origins (at least one required)
Cors__AllowedOrigins__0=http://localhost:3000
Cors__AllowedOrigins__1=https://your-frontend-domain.com
